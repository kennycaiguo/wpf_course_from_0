<Window x:Class="WiredbrainCoffeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WiredbrainCoffeeApp" 
        xmlns:controls="clr-namespace:WiredbrainCoffeeApp.Controls"
        xmlns:view="clr-namespace:WiredbrainCoffeeApp.View"
        xmlns:viewmodel="clr-namespace:WiredbrainCoffeeApp.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" d:DesignHeight="600" d:DesignWidth="700" FontSize="20">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodel:CustomerViewModel}">
            <view:CustomersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodel:ProductViewModel}">
            <view:ProductsView/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!--主菜单-->
        <Menu FontSize="20">
            <MenuItem Header="_View">
                <MenuItem Header="_Customers"/>
                <MenuItem Header="_Products"/>
            </MenuItem>
        </Menu>
        <!--Headers-->
        <controls:HeaderControl  Grid.Row="1" />
        
       <!--客户视图控件-->
        <ContentControl Grid.Row="2" Content="{Binding SelectedViewModel}"/>


        <!--Status Bar-->
        <StatusBar Grid.Row="3">
            <StatusBarItem FontSize="20" Content="(C) WiredBrain Coffee" />
        </StatusBar>
        
    </Grid>
</Window>


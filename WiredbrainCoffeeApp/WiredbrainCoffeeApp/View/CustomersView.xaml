<UserControl x:Class="WiredbrainCoffeeApp.View.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WiredbrainCoffeeApp.View" 
             xmlns:converter="clr-namespace:WiredbrainCoffeeApp.Converter"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>
        <converter:NavigationSideToGridColumnConverter 
            x:Key="NsToGcCon"/>
        <DataTemplate x:Key="CustDtTmp">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding FirstName}" FontWeight="Bold" />
                <TextBlock Text="{Binding LastName}" Margin="10 0 0 0" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!--Customer List-->
        <Grid Grid.Column="{Binding Path=NavigationSide,
            Converter={StaticResource NsToGcCon}}"
            Background="#777" Width="260">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Margin="10" Width="75" Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/add.png"  Height="18" Margin="0 0 5 0 "/>
                        <TextBlock Text="Add"/>
                    </StackPanel>
                </Button>
                <Button Content="Delete" Width="75" Margin="0 10 10 10"
                        Command="{Binding DeleteCommand}"
                        />
                <Button  Margin="0 10 10 10" Width="75" Command="{Binding MoveNavigationCommand}">
                    <Image Source="/Images/move.png" Height="18" />
                </Button>
            </StackPanel>
            <ListView 
                      ItemsSource="{Binding Path=Customers}"
                      SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                      Grid.Row="1" Margin="10 0 10 10" 
                      ItemTemplate="{StaticResource CustDtTmp}" />




        </Grid>
        <!--Customer Detail-->
        <StackPanel  Grid.Column="1" Margin="10" Visibility="{Binding IsCustomerSelected,
            Converter={StaticResource BoolToVisitable}}">
            
            <Label Content="First Name:" />
            <TextBox Text="{Binding  Path=SelectedCustomer.FirstName, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Last Name:" />
            <TextBox Text="{Binding  Path=SelectedCustomer.LastName, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
            <CheckBox IsChecked="{Binding  Path=SelectedCustomer.IsDeveloper, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="0 10 0 0" >
                IsDeveloper
            </CheckBox>
        </StackPanel>
    </Grid>
</UserControl>
